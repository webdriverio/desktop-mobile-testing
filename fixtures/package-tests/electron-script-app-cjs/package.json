{
  "name": "electron-script-app-example-cjs",
  "version": "0.0.0",
  "description": "Simple Electron app example using wdio-electron-service (CJS)",
  "main": "out/main/index.js",
  "type": "commonjs",
  "private": true,
  "scripts": {
    "clean": "pnpx shx rm -rf out node_modules",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron .",
    "test": "cross-env DEBUG=wdio-electron-service wdio run wdio.conf.ts",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@types/semver": "^7.7.1",
    "@wdio/cli": "^9.24.0",
    "@wdio/electron-service": "workspace:*",
    "@wdio/globals": "^9.23.0",
    "@wdio/local-runner": "^9.24.0",
    "@wdio/mocha-framework": "^9.24.0",
    "@wdio/spec-reporter": "^9.24.0",
    "cross-env": "^10.1.0",
    "electron": "40.4.1",
    "electron-vite": "^5.0.0",
    "semver": "^7.7.4",
    "typescript": "^5.9.3"
  },
  "keywords": ["electron", "electron-vite", "webdriverio", "testing", "example"],
  "author": "WebDriverIO Community",
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": ["electron"]
  }
}
