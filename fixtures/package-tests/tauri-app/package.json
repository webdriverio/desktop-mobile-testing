{
  "name": "tauri-app-example",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "tauri": "tauri",
    "dev": "tauri dev",
    "clean:dist": "rm -rf dist",
    "build:js": "pnpm --filter @wdio/tauri-plugin build:js",
    "build:web": "tsx scripts/build-web.ts",
    "build": "pnpm build:js && pnpm build:web && tauri build",
    "build:debug": "pnpm build:js && pnpm build:web && tauri build --debug",
    "test": "cross-env DEBUG=@wdio/tauri-service wdio run wdio.conf.ts"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-fs": "^2.0.0",
    "@tauri-apps/plugin-log": "2.8.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@wdio/cli": "^9.0.0",
    "@wdio/local-runner": "^9.0.0",
    "@wdio/mocha-framework": "^9.0.0",
    "@wdio/spec-reporter": "^9.0.0",
    "@wdio/tauri-service": "workspace:*",
    "typescript": "^5.0.0"
  }
}
