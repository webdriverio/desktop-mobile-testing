{
  "name": "electron-builder-app-example-cjs",
  "version": "0.0.0",
  "description": "Electron Builder app example using wdio-electron-service (CJS)",
  "main": "dist/main/index.js",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "clean": "pnpx shx rm -rf dist dist-electron node_modules",
    "dev": "electron-vite dev",
    "build": "electron-vite build && electron-builder",
    "preview": "electron-vite preview",
    "start": "electron .",
    "test": "cross-env DEBUG=wdio-electron-service wdio run wdio.conf.ts",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@wdio/cli": "^9.27.0",
    "@wdio/electron-service": "workspace:*",
    "@wdio/globals": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "cross-env": "^10.1.0",
    "electron": "41.0.2",
    "electron-builder": "26.8.1",
    "electron-vite": "^5.0.0",
    "typescript": "^5.9.3"
  },
  "keywords": ["electron", "builder", "electron-vite", "webdriverio", "testing", "example"],
  "author": "WebDriverIO Community",
  "license": "MIT",
  "build": {
    "appId": "com.example.builder-app",
    "productName": "Builder App Example",
    "executableName": "builder-app-example",
    "directories": {
      "output": "dist-electron"
    },
    "files": ["dist/**/*", "package.json"],
    "mac": {
      "category": "public.app-category.utilities",
      "target": "dir",
      "identity": null
    },
    "win": {
      "target": "dir"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": ["electron", "esbuild"],
    "overrides": {
      "@wdio/utils": "file:../../../../wdio-utils-9.23.0.tgz",
      "minimatch": "10.2.2"
    }
  }
}
