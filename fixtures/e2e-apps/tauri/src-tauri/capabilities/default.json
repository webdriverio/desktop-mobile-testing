{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability - includes core app commands, WDIO plugin, WebDriver, and deep-link permissions",
  "windows": ["splash", "main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:event:default",
    "deep-link:default",
    "wdio:default",
    "wdio-webdriver:default"
  ]
}
