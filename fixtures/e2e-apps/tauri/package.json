{
  "name": "tauri-e2e-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "tauri": "tauri",
    "dev": "vite",
    "build:js": "pnpm --filter @wdio/tauri-plugin build:js",
    "build:web": "vite build",
    "build": "pnpm build:js && pnpm build:web && tauri build",
    "build:debug": "pnpm build:js && pnpm build:web && tauri build --debug && tsx scripts/copy-debug-binary.ts",
    "clean:dist": "pnpm dlx shx rm -rf ./dist && pnpm dlx shx mkdir -p ./dist",
    "test": "wdio run ./wdio.conf.ts"
  },
  "dependencies": {
    "@tauri-apps/api": "2.10.1",
    "@tauri-apps/plugin-deep-link": "2.4.6",
    "@tauri-apps/plugin-fs": "2.4.5",
    "@tauri-apps/plugin-log": "2.8.0",
    "@wdio/tauri-plugin": "workspace:*"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.10.0",
    "@wdio/cli": "^9.23.0",
    "@wdio/local-runner": "^9.23.0",
    "@wdio/mocha-framework": "^9.23.0",
    "@wdio/spec-reporter": "^9.0.0",
    "@wdio/tauri-service": "workspace:*",
    "typescript": "^5.0.0",
    "vite": "^7.3.1"
  }
}
