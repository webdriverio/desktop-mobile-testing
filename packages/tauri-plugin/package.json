{
  "name": "@wdio/tauri-plugin",
  "version": "1.0.0-next.0",
  "description": "Tauri plugin providing execute and mocking capabilities for WebDriverIO testing",
  "homepage": "https://github.com/webdriverio/desktop-mobile/tree/main/packages/tauri-plugin",
  "private": true,
  "type": "module",
  "main": "./dist-js/index.js",
  "types": "./dist-types/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist-types/index.d.ts",
        "default": "./dist-js/index.js"
      }
    }
  },
  "files": ["README.md", "dist-js", "dist-types", "LICENSE"],
  "scripts": {
    "build:guest-js": "tsx scripts/build-guest-js.ts",
    "build:types": "tsx scripts/build-types.ts",
    "build": "pnpm build:guest-js && pnpm build:types"
  },
  "keywords": ["tauri", "webdriverio", "testing", "automation"],
  "author": "WebDriverIO Community",
  "license": "MIT",
  "dependencies": {
    "@tauri-apps/api": "2.9.1",
    "@tauri-apps/plugin-log": "2.8.0",
    "@vitest/spy": "^4.0.17",
    "@wdio/native-spy": "workspace:*"
  },
  "devDependencies": {
    "@wdio/bundler": "workspace:*",
    "typescript": "^5.0.0"
  }
}
