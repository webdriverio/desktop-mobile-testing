{
  "name": "@wdio/electron-service",
  "version": "10.0.0-next.9",
  "description": "WebdriverIO service to enable Electron testing",
  "author": "Sam Maister <goosewobbler@protonmail.com>",
  "homepage": "https://github.com/webdriverio/desktop-mobile/tree/main/packages/electron-service",
  "license": "MIT",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": [
      {
        "import": {
          "types": "./dist/esm/index.d.ts",
          "default": "./dist/esm/index.js"
        },
        "require": {
          "types": "./dist/cjs/index.d.ts",
          "default": "./dist/cjs/index.js"
        }
      },
      "./dist/cjs/index.js"
    ]
  },
  "engines": {
    "node": "^18.12.0 || ^20.9.0 || >=22.11.0"
  },
  "scripts": {
    "clean": "shx rm -rf dist coverage .turbo",
    "build": "tsx ../../scripts/build-package.ts",
    "dev": "tsx ../../scripts/build-package.ts --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --coverage",
    "test:unit": "vitest run --coverage",
    "test:dev": "vitest --coverage",
    "lint": "biome check ."
  },
  "keywords": [
    "webdriverio",
    "wdio",
    "wdio-service",
    "electron",
    "chromedriver",
    "tests"
  ],
  "peerDependencies": {
    "electron": "*",
    "webdriverio": ">9.0.0"
  },
  "peerDependenciesMeta": {
    "electron": {
      "optional": true
    },
    "webdriverio": {
      "optional": false
    }
  },
  "dependencies": {
    "@babel/parser": "^7.29.0",
    "@electron/fuses": "^2.1.0",
    "@electron/packager": "^19.0.5",
    "@wdio/electron-cdp-bridge": "workspace:*",
    "@wdio/globals": "catalog:default",
    "@wdio/logger": "catalog:default",
    "@wdio/native-types": "workspace:*",
    "@wdio/native-utils": "workspace:*",
    "compare-versions": "^6.1.1",
    "debug": "^4.4.3",
    "deepmerge-ts": "^7.1.5",
    "electron-to-chromium": "^1.5.313",
    "fast-copy": "^4.0.2",
    "find-versions": "^6.0.0",
    "get-port": "^7.1.0",
    "puppeteer-core": "^24.39.1",
    "recast": "^0.23.9",
    "webdriverio": "catalog:default",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@electron-forge/shared-types": "^7.11.1",
    "@puppeteer/browsers": "^2.13.0",
    "@types/debug": "^4.1.12",
    "@types/electron-to-chromium": "^1.5.0",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@wdio/native-spy": "workspace:*",
    "@wdio/types": "catalog:default",
    "builder-util": "^26.8.0",
    "electron": "catalog:default",
    "jsdom": "^28.1.0",
    "nock": "^14.0.13",
    "shx": "^0.4.0",
    "tinyspy": "^4.0.4",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/webdriverio/desktop-mobile.git",
    "directory": "packages/electron-service"
  }
}
